# 🏝️ 比奇堡開發團隊 — 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Bot Tokens（每個角色一個 Discord Application）
DISCORD_BOT_TOKEN_BOB=
DISCORD_BOT_TOKEN_PATRICK=
DISCORD_BOT_TOKEN_GARY=

# Channel IDs
CHANNEL_GENERAL=
KIRO_USAGE_CHANNEL_ID=

# Slash Bot 設定
DISCORD_GUILD_ID=
SLASH_BOT_CHANNEL_ID=

# Git（commit 作者信箱）
GIT_EMAIL=

# AWS（slash-bot 查詢 Athena 用，SESSION_TOKEN 會過期需定期更新）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
