# 🏔️ 南方公園開發團隊 — 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Bot Tokens（每個角色一個 Discord Application）
DISCORD_BOT_TOKEN_CARTMAN=
DISCORD_BOT_TOKEN_STAN=
DISCORD_BOT_TOKEN_KYLE=
DISCORD_BOT_TOKEN_KENNY=

# Channel IDs
CHANNEL_GENERAL=

# Git（commit 作者信箱）
GIT_EMAIL=

# Figma MCP（設計稿讀取）
# 取得方式：Figma → 帳號設定 → Security → Personal access tokens
FIGMA_API_KEY=

# Jira MCP（ticket 管理）
# JIRA_URL: 你的 Jira 站台，例如 https://yourteam.atlassian.net
# JIRA_USERNAME: 登入用的 email
# JIRA_API_TOKEN: Atlassian → 帳號設定 → Security → API tokens
# JIRA_PROJECT_KEY: 目標 project 代號，例如 DEV、SOUTH
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
