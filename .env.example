# 🏔️ 南方公園開發團隊 — 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Bot Tokens（每個角色一個 Discord Application）
DISCORD_BOT_TOKEN_CARTMAN=
DISCORD_BOT_TOKEN_STAN=
DISCORD_BOT_TOKEN_KYLE=
DISCORD_BOT_TOKEN_KENNY=

# Channel IDs
CHANNEL_GENERAL=

# Git（commit 作者信箱）
GIT_EMAIL=

# Figma MCP（設計稿讀取）
# 取得方式：Figma → 帳號設定 → Security → Personal access tokens
FIGMA_API_KEY=

# Jira MCP（ticket 管理）套件：@aashari/mcp-server-atlassian-jira
# ATLASSIAN_SITE_NAME: 站台子網域，例如 yourteam（非完整 URL）
# ATLASSIAN_USER_EMAIL: 登入用的 email
# ATLASSIAN_API_TOKEN: Atlassian → 帳號設定 → Security → API tokens
# JIRA_PROJECT_KEY: 目標 project 代號，例如 DEV、SOUTH
ATLASSIAN_SITE_NAME=
ATLASSIAN_USER_EMAIL=
ATLASSIAN_API_TOKEN=
JIRA_PROJECT_KEY=
